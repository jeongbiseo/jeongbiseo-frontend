# 백엔드 서버 Origin입니다. /api/v1 경로는 포함하지 않습니다.
VITE_API_URL=https://cartlab.store

# 백엔드 인증 배포 전 로컬 보호 페이지 개발에만 사용합니다.
# Production에서는 코드상 활성화되지 않습니다.
VITE_USE_MOCK_AUTH=true

# 소셜 로그인 client id (카카오 REST API 키 / 구글 OAuth client id)
# 팀에서 전달받아 채웁니다. 비어 있으면 해당 소셜 로그인이 동작하지 않습니다.
VITE_KAKAO_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
