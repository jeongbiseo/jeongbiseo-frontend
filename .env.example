# 백엔드 서버 Origin입니다. /api/v1 경로는 포함하지 않습니다.
VITE_API_URL=https://cartlab.store
VITE_APP_URL=https://app.cartlab.store

# OAuth 콜백의 기준이 되는 프론트엔드 Origin입니다. 마지막 /는 생략합니다.
# 로컬은 http://localhost:5173, Production은 실제 배포 주소를 사용합니다.
VITE_APP_URL=http://localhost:5173

# 소셜 로그인 client id (카카오 REST API 키 / 구글 OAuth client id)
# 팀에서 전달받아 채웁니다. 비어 있으면 로그인이 동작하지 않아 보호 페이지에 접근할 수 없습니다.
VITE_KAKAO_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
